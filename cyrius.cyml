[package]
name = "sakshi"
version = "${file:VERSION}"
description = "Sakshi — the silent witness. Tracing, error handling, and structured logging for Cyrius."
license = "GPL-3.0-only"
repository = "https://github.com/MacCracken/sakshi"
language = "cyrius"
cyrius = "6.0.1"

[build]
entry = "programs/smoke.cyr"
output = "build/sakshi-smoke"
defines = ["SAKSHI_SMOKE"]

[deps]
stdlib = ["syscalls", "string", "fmt", "assert", "alloc", "fnptr", "bench"]
