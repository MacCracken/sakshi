# Test: sakshi — spans, ring buffer, UDP, binary decode, error codes, trace
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/assert.cyr"
include "lib/fnptr.cyr"

include "src/lib.cyr"

# ================================================================
# Error codes
# ================================================================
test_group("error pack/unpack");
var err = sakshi_err_new(ERR_NOT_FOUND, ERR_CAT_IO);
assert_eq(sakshi_err_code(err), 3, "err_code");
assert_eq(sakshi_err_category(err), 2, "err_category");
assert_eq(sakshi_err_context(err), 0, "ctx default");

test_group("error with context");
var err2 = sakshi_err_with_ctx(ERR_TIMEOUT, ERR_CAT_NET, 0xDEAD);
assert_eq(sakshi_err_code(err2), 5, "ctx code");
assert_eq(sakshi_err_category(err2), 7, "ctx cat");
assert_eq(sakshi_err_context(err2), 0xDEAD, "ctx val");

test_group("error predicates");
assert(sakshi_is_ok(ERR_OK) == 1, "is_ok zero");
assert(sakshi_is_err(err) == 1, "is_err packed");

# ================================================================
# Trace
# ================================================================
test_group("trace levels");
sakshi_fatal("full fatal", 10);
sakshi_error("full error", 10);
sakshi_warn("full warn", 9);
sakshi_info("full info", 9);
assert_eq(sakshi_get_level(), SK_INFO, "default level");
sakshi_set_level(SK_DEBUG);
sakshi_debug("debug on", 8);
sakshi_set_level(SK_INFO);

# ================================================================
# Spans
# ================================================================
test_group("span enter/exit");
sakshi_span_enter("outer", 5);
assert_eq(sakshi_span_depth(), 1, "depth 1");
sakshi_span_enter("inner", 5);
assert_eq(sakshi_span_depth(), 2, "depth 2");

test_group("err_at_span");
var err3 = sakshi_err_at_span(ERR_BUSY, ERR_CAT_RUNTIME);
assert_eq(sakshi_err_context(err3), 2, "at_span depth 2");

sakshi_span_exit();
assert_eq(sakshi_span_depth(), 1, "after inner exit");
sakshi_span_exit();
assert_eq(sakshi_span_depth(), 0, "after outer exit");

test_group("trace ID");
sakshi_trace_set(0xABCD1234);
assert_eq(sakshi_trace_id(), 0xABCD1234, "trace id set/get");
sakshi_trace_set(0);
assert_eq(sakshi_trace_id(), 0, "trace id cleared");

test_group("span underflow");
sakshi_span_exit();
assert_eq(sakshi_span_depth(), 0, "no underflow");

# ================================================================
# Ring buffer
# ================================================================
test_group("ring buffer write");
sakshi_output_buffer();
# sakshi_output_buffer emits 1 metadata event, then 2 log events = 3 total
sakshi_info("ring one", 8);
sakshi_warn("ring two", 8);
assert_eq(sakshi_ring_event_count(), 3, "3 events (1 meta + 2 log)");
assert_gt(sakshi_ring_len(), 0, "ring has bytes");

test_group("ring buffer read");
var raw[4096];
var n = sakshi_ring_read_raw(&raw, 4096);
assert_gt(n, 0, "read_raw > 0");

test_group("ring buffer decode");
var text[256];
var text_len: i64 = 0;
var consumed = sakshi_ring_decode_event(&raw, n, &text, 256, &text_len);
assert_gt(consumed, 0, "decode consumed > 0");
assert_gt(text_len, 0, "decode text_len > 0");

test_group("ring buffer clear");
sakshi_ring_clear();
assert_eq(sakshi_ring_event_count(), 0, "cleared count");
assert_eq(sakshi_ring_len(), 0, "cleared len");

# ================================================================
# Atomic ring buffer (v2.3.0) — MPSC, lock-free reservation writer
# ================================================================
test_group("atomic ring write");
sakshi_aring_clear();
sakshi_output_atomic_ring();
# sakshi_output_atomic_ring emits 1 metadata event, then 2 log events = 3 total
sakshi_info("aring one", 9);
sakshi_warn("aring two", 9);
assert_eq(sakshi_aring_event_count(), 3, "3 events (1 meta + 2 log)");
assert_gt(sakshi_aring_len(), 0, "atomic ring has bytes");

test_group("atomic ring read");
var araw[4096];
var an = sakshi_aring_read_raw(&araw, 4096);
assert_gt(an, 0, "aring read_raw > 0");

test_group("atomic ring decode (shared binary format)");
# Same 12-byte-header layout as SK_OUT_BUFFER, so sakshi_ring_decode_event
# decodes the atomic ring's bytes unchanged.
var atext[256];
var atext_len: i64 = 0;
var aconsumed = sakshi_ring_decode_event(&araw, an, &atext, 256, &atext_len);
assert_gt(aconsumed, 0, "aring decode consumed > 0");
assert_gt(atext_len, 0, "aring decode text_len > 0");

test_group("atomic ring reservation is non-overlapping");
# Each event reserves a unique byte range via atomic_fetch_add, so N events
# advance the cursor by exactly sum(event_size). Two 9-byte messages after the
# 8-byte meta event = 3 events, (12+8) + (12+9) + (12+9) = 62 bytes.
assert_eq(sakshi_aring_len(), 62, "cursor = sum of reserved event sizes");

test_group("atomic ring clear");
sakshi_aring_clear();
assert_eq(sakshi_aring_event_count(), 0, "cleared count");
assert_eq(sakshi_aring_len(), 0, "cleared len");

# Switch back to stderr
sakshi_set_output(SK_OUT_STDERR);

# ================================================================
# File output
# ================================================================
test_group("file output");
var fd = sakshi_output_file("/tmp/sakshi_full_test.log");
assert_gt(fd, 0, "file open");
sakshi_info("file test", 9);
sakshi_output_file_close();

# ================================================================
# Level filtering
# ================================================================
test_group("level filtering");
sakshi_set_level(SK_INFO);
sakshi_debug("should not appear", 17);
sakshi_trace("should not appear", 17);
sakshi_set_level(SK_TRACE);
assert_eq(sakshi_get_level(), SK_TRACE, "trace level set");
sakshi_trace("trace visible", 13);
sakshi_set_level(SK_INFO);

# ================================================================
# Span overflow
# ================================================================
test_group("span overflow (16-deep)");
for (var si = 0; si < 16; si = si + 1) {
    sakshi_span_enter("fill", 4);
}
assert_eq(sakshi_span_depth(), 16, "depth at max");
# 17th enter should be silently ignored
sakshi_span_enter("overflow", 8);
assert_eq(sakshi_span_depth(), 16, "depth still 16");
# unwind all
for (var si = 0; si < 16; si = si + 1) {
    sakshi_span_exit();
}
assert_eq(sakshi_span_depth(), 0, "depth back to 0");

# ================================================================
# Output fd redirect
# ================================================================
test_group("output fd redirect");
var devnull = _sk_open("/dev/null", 1, 0);
assert_gt(devnull, 0, "open /dev/null");
sakshi_set_output_fd(devnull);
sakshi_info("to devnull", 10);
sakshi_set_output_fd(2);
syscall(_SK_SYS_CLOSE, devnull);

# ================================================================
# Edge cases
# ================================================================
test_group("error edge: max values");
var emax = sakshi_err_with_ctx(0xFFFF, 0xFFFF, 0xFFFFFFFF);
assert_eq(sakshi_err_code(emax), 0xFFFF, "max code");
assert_eq(sakshi_err_category(emax), 0xFFFF, "max cat");
assert_eq(sakshi_err_context(emax), 0xFFFFFFFF, "max ctx");

test_group("error edge: overflow clamp");
var eover = sakshi_err_new(0x1FFFF, 0x1FFFF);
assert_eq(sakshi_err_code(eover), 0xFFFF, "code clamped");
assert_eq(sakshi_err_category(eover), 0xFFFF, "cat clamped");

# ================================================================
# Subscriber hook (v2.1.0, roadmap #7)
# ================================================================
test_group("subscriber hook");
var hk_count: i64 = 0;
var hk_last_level: i64 = 0;
var hk_last_msg_len: i64 = 0;
var hk_last_elapsed: i64 = 0;

fn _sk_test_hook(ts, level, category, msg, msg_len, elapsed_ns) {
    hk_count = hk_count + 1;
    hk_last_level = level;
    hk_last_msg_len = msg_len;
    hk_last_elapsed = elapsed_ns;
    return 0;
}

sakshi_set_emit_hook(&_sk_test_hook);
sakshi_info("hi", 2);
assert_eq(hk_count, 1, "hook fired for info");
assert_eq(hk_last_level, 3, "hook saw SK_INFO");
assert_eq(hk_last_msg_len, 2, "hook saw msg_len");
assert_eq(hk_last_elapsed, 0, "log events pass elapsed=0");

sakshi_span_enter("scope", 5);
assert_eq(hk_count, 2, "hook fired for span_enter");
assert_eq(hk_last_level, 10, "hook saw SK_SPAN_ENTER");

sakshi_span_exit();
assert_eq(hk_count, 3, "hook fired for span_exit");
assert_eq(hk_last_level, 11, "hook saw SK_SPAN_EXIT");
assert_gt(hk_last_elapsed, 0, "span_exit reported elapsed");

sakshi_clear_emit_hook();
sakshi_set_output_fd(2);
sakshi_info("post-clear", 10);
assert_eq(hk_count, 3, "hook not fired after clear");

# ================================================================
# Key=value structured emit (sakshi_log_kv) — folded from agnosys
# ================================================================
test_group("kv logging");
var kv_count: i64 = 0;
var kv_len: i64 = 0;
var kv_buf[64];
fn _kv_hook(ts, level, category, msg, msg_len, elapsed_ns) {
    kv_count = kv_count + 1;
    kv_len = msg_len;
    var i = 0;
    while (i < msg_len) {
        if (i >= 64) { break; }
        store8(&kv_buf + i, load8(msg + i));
        i = i + 1;
    }
    return 0;
}

sakshi_set_emit_hook(&_kv_hook);
sakshi_set_level(SK_INFO);
sakshi_log_kv(SK_INFO, "hi", 2, "k", 1, "v", 1);   # composes "hi k=v"
assert_eq(kv_count, 1, "kv emitted one event");
assert_eq(kv_len, 6, "kv composed 'hi k=v' = 6 bytes");
assert_eq(load8(&kv_buf), 104, "kv byte0 is 'h'");
assert_eq(load8(&kv_buf + 2), 32, "kv separator is space");
assert_eq(load8(&kv_buf + 3), 107, "kv key byte is 'k'");
assert_eq(load8(&kv_buf + 4), 61, "kv pair joiner is '='");
assert_eq(load8(&kv_buf + 5), 118, "kv value byte is 'v'");

# Runtime level gate: a DEBUG kv under an INFO ceiling must not emit.
sakshi_log_kv(SK_DEBUG, "x", 1, "k", 1, "v", 1);
assert_eq(kv_count, 1, "kv respects runtime level filter");

sakshi_clear_emit_hook();
sakshi_set_output_fd(2);

# ================================================================
# Cycle-counter clock (v2.2.0)
# ================================================================
test_group("clock: cycle counter");

# _sk_clock_init runs lazily on first _sk_now_ns; the trace/span calls above
# have already triggered it. Both freq + scale must be populated.
assert_gt(_sk_tsc_freq_hz, 500000000, "freq > 500 MHz");
assert_lt(_sk_tsc_freq_hz, 10000000000, "freq < 10 GHz");
assert_gt(_sk_tsc_scale, 0, "Q32 scale set");

# Tick reads must be monotonic across a tight loop.
var prev_ticks = _sk_now_ticks();
var mono_ok = 1;
for (var i = 0; i < 1000; i = i + 1) {
    var cur_ticks = _sk_now_ticks();
    if (cur_ticks < prev_ticks) { mono_ok = 0; }
    prev_ticks = cur_ticks;
}
assert_eq(mono_ok, 1, "ticks monotonic over 1000 reads");

# ticks→ns scale agrees with the kernel: nanosleep(10 ms) → ns delta in [8, 12] ms.
# nanosleep number is a literal 35 (a `var` defeats the macOS/Windows reroute —
# cyrius issue 2026-06-16); nap is [16] (a {tv_sec,tv_nsec} timespec is 16 bytes,
# and var[N] is byte-sized in cyrius — [2] reserved only 8 B and ran the +8 store OOB).
var ns0 = _sk_ticks_to_ns(_sk_now_ticks());
var nap[16];
store64(&nap, 0);
store64(&nap + 8, 10000000);
syscall(35, &nap, 0);
var ns1 = _sk_ticks_to_ns(_sk_now_ticks());
var ns_delta = ns1 - ns0;
assert_gt(ns_delta, 8000000, "ns_delta > 8 ms");
assert_lt(ns_delta, 12000000, "ns_delta < 12 ms");

# Init is idempotent — second call must not change cached state.
var f = _sk_tsc_freq_hz;
var s = _sk_tsc_scale;
_sk_clock_init();
assert_eq(_sk_tsc_freq_hz, f, "init idempotent: freq unchanged");
assert_eq(_sk_tsc_scale, s, "init idempotent: scale unchanged");

# v2.2.1: explicit recalibration. Must run a fresh measurement (no early
# return) and produce a freq within 1% of the original — same host, same
# TSC, expected to be near-identical.
var rf = sakshi_clock_recalibrate();
assert_gt(rf, 500000000, "recalibrate freq > 500 MHz");
assert_lt(rf, 10000000000, "recalibrate freq < 10 GHz");
var diff = rf - f;
if (diff < 0) { diff = 0 - diff; }
assert_lt(diff, f / 100, "recalibrate within 1% of original freq");
assert_gt(_sk_tsc_scale, 0, "scale still set after recalibrate");

var r = assert_summary();
