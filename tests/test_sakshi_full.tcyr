# Test: sakshi full profile — spans, ring buffer, UDP, binary decode
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/assert.cyr"

include "sakshi_full.cyr"

# ================================================================
# Error codes (same as slim, verify full profile parity)
# ================================================================
test_group("error pack/unpack");
var err = sakshi_err_new(ERR_NOT_FOUND, ERR_CAT_IO);
assert_eq(sakshi_err_code(err), 3, "err_code");
assert_eq(sakshi_err_category(err), 2, "err_category");
assert_eq(sakshi_err_context(err), 0, "ctx default");

test_group("error with context");
var err2 = sakshi_err_with_ctx(ERR_TIMEOUT, ERR_CAT_NET, 0xDEAD);
assert_eq(sakshi_err_code(err2), 5, "ctx code");
assert_eq(sakshi_err_category(err2), 7, "ctx cat");
assert_eq(sakshi_err_context(err2), 0xDEAD, "ctx val");

test_group("error predicates");
assert(sakshi_is_ok(ERR_OK) == 1, "is_ok zero");
assert(sakshi_is_err(err) == 1, "is_err packed");

# ================================================================
# Trace
# ================================================================
test_group("trace levels");
sakshi_error("full error", 10);
sakshi_warn("full warn", 9);
sakshi_info("full info", 9);
assert_eq(sakshi_get_level(), SK_INFO, "default level");
sakshi_set_level(SK_DEBUG);
sakshi_debug("debug on", 8);
sakshi_set_level(SK_INFO);

# ================================================================
# Spans
# ================================================================
test_group("span enter/exit");
sakshi_span_enter("outer", 5);
assert_eq(sakshi_span_depth(), 1, "depth 1");
sakshi_span_enter("inner", 5);
assert_eq(sakshi_span_depth(), 2, "depth 2");

test_group("err_at_span");
var err3 = sakshi_err_at_span(ERR_BUSY, ERR_CAT_RUNTIME);
assert_eq(sakshi_err_context(err3), 2, "at_span depth 2");

sakshi_span_exit();
assert_eq(sakshi_span_depth(), 1, "after inner exit");
sakshi_span_exit();
assert_eq(sakshi_span_depth(), 0, "after outer exit");

test_group("span underflow");
sakshi_span_exit();
assert_eq(sakshi_span_depth(), 0, "no underflow");

# ================================================================
# Ring buffer
# ================================================================
test_group("ring buffer write");
sakshi_output_buffer();
sakshi_info("ring one", 8);
sakshi_warn("ring two", 8);
assert_eq(sakshi_ring_event_count(), 2, "2 events");
assert_gt(sakshi_ring_len(), 0, "ring has bytes");

test_group("ring buffer read");
var raw[4096];
var n = sakshi_ring_read_raw(&raw, 4096);
assert_gt(n, 0, "read_raw > 0");

test_group("ring buffer decode");
var text[256];
var text_len: i64 = 0;
var consumed = sakshi_ring_decode_event(&raw, n, &text, 256, &text_len);
assert_gt(consumed, 0, "decode consumed > 0");
assert_gt(text_len, 0, "decode text_len > 0");

test_group("ring buffer clear");
sakshi_ring_clear();
assert_eq(sakshi_ring_event_count(), 0, "cleared count");
assert_eq(sakshi_ring_len(), 0, "cleared len");

# Switch back to stderr
sakshi_set_output(SK_OUT_STDERR);

# ================================================================
# File output
# ================================================================
test_group("file output");
var fd = sakshi_output_file("/tmp/sakshi_full_test.log");
assert_gt(fd, 0, "file open");
sakshi_info("file test", 9);
sakshi_output_file_close();

# ================================================================
# Level filtering
# ================================================================
test_group("level filtering");
sakshi_set_level(SK_INFO);
sakshi_debug("should not appear", 17);
sakshi_trace("should not appear", 17);
sakshi_set_level(SK_TRACE);
assert_eq(sakshi_get_level(), SK_TRACE, "trace level set");
sakshi_trace("trace visible", 13);
sakshi_set_level(SK_INFO);

# ================================================================
# Span overflow
# ================================================================
test_group("span overflow (16-deep)");
for (var si = 0; si < 16; si = si + 1) {
    sakshi_span_enter("fill", 4);
}
assert_eq(sakshi_span_depth(), 16, "depth at max");
# 17th enter should be silently ignored
sakshi_span_enter("overflow", 8);
assert_eq(sakshi_span_depth(), 16, "depth still 16");
# unwind all
for (var si = 0; si < 16; si = si + 1) {
    sakshi_span_exit();
}
assert_eq(sakshi_span_depth(), 0, "depth back to 0");

# ================================================================
# Output fd redirect
# ================================================================
test_group("output fd redirect");
var devnull = syscall(2, "/dev/null", 1, 0);
assert_gt(devnull, 0, "open /dev/null");
sakshi_set_output_fd(devnull);
sakshi_info("to devnull", 10);
sakshi_set_output_fd(2);
syscall(3, devnull);

# ================================================================
# Edge cases
# ================================================================
test_group("error edge: max values");
var emax = sakshi_err_with_ctx(0xFFFF, 0xFFFF, 0xFFFFFFFF);
assert_eq(sakshi_err_code(emax), 0xFFFF, "max code");
assert_eq(sakshi_err_category(emax), 0xFFFF, "max cat");
assert_eq(sakshi_err_context(emax), 0xFFFFFFFF, "max ctx");

test_group("error edge: overflow clamp");
var eover = sakshi_err_new(0x1FFFF, 0x1FFFF);
assert_eq(sakshi_err_code(eover), 0xFFFF, "code clamped");
assert_eq(sakshi_err_category(eover), 0xFFFF, "cat clamped");

var r = assert_summary();
