# config.cyr — compile-time configuration for sakshi
# Loads sakshi.toml via #ref at compile time.
# Consumers override defaults by defining sk_cfg_* vars before including lib.cyr,
# or by placing their own sakshi.toml in the project root.

#ref "sakshi.toml"

# Apply compile-time config to runtime state.
# Called once from lib.cyr initialization.
fn _sk_apply_config() {
    _sk_log_level = sk_cfg_log_level;
    _sk_output_target = sk_cfg_output_target;
    return 0;
}
