# output.cyr — output targets for sakshi
# v0.1.0: stderr (fd 2) as the default output target.
# v0.2.0 will add file, buffer, and network targets via #ref config.

# Default output fd — stderr
var _sk_output_fd = 2;

# Write len bytes from buf to the active output target
fn _sk_write(buf, len) {
    syscall(1, _sk_output_fd, buf, len);
    return 0;
}

# Set the output file descriptor (for testing or redirection)
fn sakshi_set_output_fd(fd) {
    _sk_output_fd = fd;
    return 0;
}
