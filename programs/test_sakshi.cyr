# test_sakshi.cyr — test program for sakshi
# Exercises error codes, tracing, spans, output targets, binary ring buffer,
# error context fields, and event decoding.

include "src/lib.cyr"

# ================================================================
# Error tests
# ================================================================
fn test_errors() {
    # Pack and unpack
    var err = sakshi_err_new(ERR_NOT_FOUND, ERR_CAT_IO);
    var code = sakshi_err_code(err);
    var cat = sakshi_err_category(err);

    if (code != 3) {
        sakshi_error("err_code mismatch", 17);
        return 1;
    }
    if (cat != 2) {
        sakshi_error("err_category mismatch", 21);
        return 1;
    }

    # Context should be 0 for sakshi_err_new
    if (sakshi_err_context(err) != 0) {
        sakshi_error("context should be 0", 19);
        return 1;
    }

    # Test sakshi_err_with_ctx
    var err2 = sakshi_err_with_ctx(ERR_TIMEOUT, ERR_CAT_NET, 0xDEAD);
    if (sakshi_err_code(err2) != 5) {
        sakshi_error("ctx err code mismatch", 21);
        return 1;
    }
    if (sakshi_err_category(err2) != 7) {
        sakshi_error("ctx err cat mismatch", 20);
        return 1;
    }
    if (sakshi_err_context(err2) != 0xDEAD) {
        sakshi_error("ctx err context mismatch", 24);
        return 1;
    }

    # Test sakshi_err_at_span (span depth = 0 here)
    var err3 = sakshi_err_at_span(ERR_INVALID, ERR_CAT_PARSE);
    if (sakshi_err_context(err3) != 0) {
        sakshi_error("at_span context should be 0", 27);
        return 1;
    }

    # Test is_ok / is_err
    if (sakshi_is_ok(ERR_OK) != 1) {
        sakshi_error("is_ok failed", 12);
        return 1;
    }
    if (sakshi_is_err(err) != 1) {
        sakshi_error("is_err failed", 13);
        return 1;
    }

    sakshi_info("error tests passed", 18);
    return 0;
}

# ================================================================
# Trace tests
# ================================================================
fn test_trace() {
    sakshi_error("this is an error", 16);
    sakshi_warn("this is a warning", 17);
    sakshi_info("this is info", 12);

    # These should be suppressed at default level (SK_INFO = 2)
    sakshi_debug("this should not appear", 22);
    sakshi_trace("this should not appear", 22);

    # Enable debug level
    sakshi_set_level(SK_DEBUG);
    sakshi_debug("debug now visible", 17);

    # Restore default
    sakshi_set_level(SK_INFO);

    sakshi_info("trace tests passed", 18);
    return 0;
}

# ================================================================
# Span tests
# ================================================================
fn test_spans() {
    sakshi_span_enter("outer_work", 10);
    sakshi_span_enter("inner_work", 10);

    if (sakshi_span_depth() != 2) {
        sakshi_error("span depth mismatch", 19);
        return 1;
    }

    # Test sakshi_err_at_span inside a span
    var err = sakshi_err_at_span(ERR_BUSY, ERR_CAT_RUNTIME);
    if (sakshi_err_context(err) != 2) {
        sakshi_error("at_span should be depth 2", 25);
        return 1;
    }

    var inner_ns = sakshi_span_exit();
    var outer_ns = sakshi_span_exit();

    if (sakshi_span_depth() != 0) {
        sakshi_error("span depth not zero", 19);
        return 1;
    }

    sakshi_info("span tests passed", 17);
    return 0;
}

# ================================================================
# Ring buffer tests (binary events)
# ================================================================
fn test_ring_buffer() {
    sakshi_output_buffer();

    # Write some events
    sakshi_info("ring test one", 13);
    sakshi_warn("ring test two", 13);

    # Verify events were recorded
    if (sakshi_ring_event_count() != 2) {
        sakshi_set_output(SK_OUT_STDERR);
        sakshi_error("expected 2 ring events", 22);
        return 1;
    }

    if (sakshi_ring_len() == 0) {
        sakshi_set_output(SK_OUT_STDERR);
        sakshi_error("ring buffer empty", 17);
        return 1;
    }

    # Read raw and decode first event
    var raw[4096];
    var n = sakshi_ring_read_raw(&raw, 4096);
    if (n == 0) {
        sakshi_set_output(SK_OUT_STDERR);
        sakshi_error("ring read_raw returned 0", 23);
        return 1;
    }

    # Decode first event to text
    var text[256];
    var text_len: i64 = 0;
    var consumed = sakshi_ring_decode_event(&raw, n, &text, 256, &text_len);
    if (consumed == 0) {
        sakshi_set_output(SK_OUT_STDERR);
        sakshi_error("decode returned 0", 17);
        return 1;
    }

    # Clear and verify
    sakshi_ring_clear();
    if (sakshi_ring_event_count() != 0) {
        sakshi_set_output(SK_OUT_STDERR);
        sakshi_error("ring not empty after clear", 26);
        return 1;
    }

    sakshi_set_output(SK_OUT_STDERR);
    sakshi_info("ring buffer tests passed", 24);
    return 0;
}

# ================================================================
# File output tests
# ================================================================
fn test_file_output() {
    var fd = sakshi_output_file("/tmp/sakshi_test.log");
    if (fd < 0) {
        sakshi_error("failed to open test log file", 28);
        return 1;
    }

    sakshi_info("file output test", 16);
    sakshi_output_file_close();

    sakshi_info("file output tests passed", 24);
    return 0;
}

# ================================================================
# Main
# ================================================================
fn main() {
    sakshi_info("sakshi test suite starting", 26);

    var r1 = test_errors();
    var r2 = test_trace();
    var r3 = test_spans();
    var r4 = test_ring_buffer();
    var r5 = test_file_output();

    if (r1 == 0 && r2 == 0 && r3 == 0 && r4 == 0 && r5 == 0) {
        sakshi_info("all tests passed", 16);
        return 0;
    }

    sakshi_error("some tests failed", 17);
    return 1;
}

var exit_code = main();
syscall(60, exit_code);
